rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return hasUserProfile()
        ? userProfile().role
        : null;
    }

    function isActiveUser() {
      return hasUserProfile() && userProfile().active == true;
    }

    function isAdmin() {
      return isActiveUser() && userRole() == "admin";
    }

    function isManagement() {
      return isActiveUser() && userRole() in ["admin", "gerencia"];
    }

    function canReadFinance() {
      return isActiveUser() && userRole() in ["admin", "gerencia", "administracion"];
    }

    function canReadProduction() {
      return isActiveUser() && userRole() in ["produccion", "taller"];
    }

    function canWriteOperational() {
      return isActiveUser()
        && userRole() in ["admin", "gerencia", "administracion", "supervisor", "fiscalizador", "encargado", "equipo_campo", "campo", "instalador", "produccion", "taller"];
    }

    function canManageTasks() {
      return isActiveUser()
        && userRole() in ["admin", "gerencia"];
    }

    function isAssignedTeam(teamId) {
      return isActiveUser()
        && teamId != null
        && userProfile().assignedTeamIds is list
        && teamId in userProfile().assignedTeamIds;
    }

    function canReadTaskData(data) {
      return isManagement()
        || canManageTasks()
        || isAssignedToWork(data.obraId)
        || data.asignadoAId == request.auth.uid
        || data.fiscalizadorId == request.auth.uid
        || isAssignedTeam(data.asignadoAId);
    }

    function canWriteTaskData(data) {
      return isManagement()
        || canManageTasks()
        || (
          isActiveUser()
          && userRole() in ["supervisor", "fiscalizador"]
          && (isAssignedToWork(data.obraId) || data.fiscalizadorId == request.auth.uid)
        )
        || (
          isActiveUser()
          && userRole() in ["equipo_campo", "campo", "instalador"]
          && (
            data.asignadoAId == request.auth.uid
            || isAssignedTeam(data.asignadoAId)
            || isAssignedToWork(data.obraId)
          )
        );
    }

    function canReadWorkdayData(data) {
      return isManagement()
        || canManageTasks()
        || (
          isActiveUser()
          && userRole() in ["supervisor", "fiscalizador"]
          && isAssignedToWork(data.obraId)
        )
        || data.userId == request.auth.uid
        || isAssignedToWork(data.obraId)
        || isAssignedTeam(data.equipoId);
    }

    function isAssignedToWork(workId) {
      return isActiveUser()
        && userProfile().assignedWorkIds is list
        && workId in userProfile().assignedWorkIds;
    }

    function isWorkCreator(workId) {
      return isActiveUser()
        && exists(/databases/$(database)/documents/obras/$(workId))
        && get(/databases/$(database)/documents/obras/$(workId)).data.createdBy == request.auth.uid;
    }

    function canReadWork(workId) {
      return isManagement() || canReadFinance() || canReadProduction() || isAssignedToWork(workId) || isWorkCreator(workId);
    }

    function canWriteWork(workId) {
      return isManagement() || canReadFinance() || isAssignedToWork(workId) || isWorkCreator(workId);
    }

    function canReadOperationalRecord() {
      return isManagement() || canReadProduction() || isAssignedToWork(resource.data.obraId) || isWorkCreator(resource.data.obraId);
    }

    function canCreateOperationalRecord() {
      return isManagement() || canReadProduction() || isAssignedToWork(request.resource.data.obraId) || isWorkCreator(request.resource.data.obraId);
    }

    match /users/{uid} {
      allow get: if (isSignedIn() && request.auth.uid == uid) || isManagement();
      allow list: if isManagement();
      allow create, update, delete: if isAdmin();
    }

    match /obras/{obraId} {
      allow read: if canReadWork(obraId);
      allow create: if canReadFinance();
      allow update: if canWriteWork(obraId);
      allow delete: if isManagement();
    }

    match /rubrosAvance/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if canWriteOperational() && canCreateOperationalRecord();
      allow update, delete: if canWriteOperational() && canReadOperationalRecord();
    }

    match /reportesAvance/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if canWriteOperational() && canCreateOperationalRecord();
      allow update, delete: if isManagement();
    }

    match /actividadesAvance/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if canWriteOperational() && canCreateOperationalRecord();
      allow update, delete: if isManagement();
    }

    match /materialesPendientes/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if canWriteOperational() && canCreateOperationalRecord();
      allow update: if canWriteOperational() && canReadOperationalRecord();
      allow delete: if isManagement();
    }

    match /movimientosFinancieros/{id} {
      allow read, write: if canReadFinance();
    }

    match /cheques/{id} {
      allow read, write: if canReadFinance();
    }

    match /cobros/{id} {
      allow read, write: if canReadFinance();
    }

    match /oportunidades/{id} {
      allow read, write: if canReadFinance();
    }

    match /clientes/{id} {
      allow read, write: if canReadFinance();
    }

    match /proveedores/{id} {
      allow read, write: if canReadFinance();
    }

    match /cuadrillas/{id} {
      allow read: if isActiveUser();
      allow write: if isActiveUser()
        && userRole() in ["admin", "gerencia", "supervisor", "fiscalizador", "encargado", "instalador", "equipo_campo", "campo"];
    }

    match /tareasInstalacion/{id} {
      allow read: if isActiveUser();
      allow write: if isActiveUser()
        && userRole() in ["admin", "gerencia", "supervisor", "encargado", "instalador"];
    }

    match /jornadasInstalacion/{id} {
      allow read: if isActiveUser();
      allow write: if isActiveUser()
        && userRole() in ["admin", "gerencia", "supervisor", "fiscalizador", "encargado", "instalador", "equipo_campo", "campo"];
    }

    match /tareas/{id} {
      allow read: if isActiveUser() && canReadTaskData(resource.data);
      allow create: if isActiveUser() && canWriteTaskData(request.resource.data);
      allow update: if isActiveUser() && canWriteTaskData(resource.data) && canWriteTaskData(request.resource.data);
      allow delete: if isManagement();
    }

    match /jornadasCampo/{id} {
      allow read: if isActiveUser() && canReadWorkdayData(resource.data);
      allow create: if isActiveUser()
        && userRole() in ["admin", "gerencia", "equipo_campo", "campo", "instalador"]
        && (request.resource.data.userId == request.auth.uid || isManagement());
      allow update: if isActiveUser()
        && (
          isManagement()
          || canManageTasks()
          || resource.data.userId == request.auth.uid
          || isAssignedTeam(resource.data.equipoId)
        );
      allow delete: if isManagement();
    }

    match /asignacionesCampo/{id} {
      allow read: if isActiveUser()
        && (
          isManagement()
          || isAssignedToWork(resource.data.obraId)
          || resource.data.usuarioResponsableId == request.auth.uid
        );
      allow create: if isActiveUser()
        && userRole() in ["admin", "gerencia", "fiscalizador", "supervisor"]
        && (isManagement() || isAssignedToWork(request.resource.data.obraId));
      allow update: if isActiveUser()
        && (
          isManagement()
          || (
            userRole() in ["fiscalizador", "supervisor"]
            && isAssignedToWork(resource.data.obraId)
          )
          || resource.data.usuarioResponsableId == request.auth.uid
        );
      allow delete: if isManagement();
    }

    match /produccionEventos/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if isActiveUser()
        && userRole() in ["admin", "gerencia", "produccion", "taller"]
        && (isManagement() || isAssignedToWork(request.resource.data.obraId) || userRole() in ["produccion", "taller"]);
      allow update, delete: if isManagement();
    }

    match /instalacionEventos/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if canWriteOperational() && canCreateOperationalRecord();
      allow update, delete: if isManagement();
    }

    match /actividades/{id} {
      allow read: if canReadOperationalRecord();
      allow create: if isActiveUser() && canCreateOperationalRecord();
      allow update, delete: if isManagement();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
