rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function active() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc().active == true;
    }

    function canUseWork(obraId) {
      return active()
        && (
          userDoc().role in ["admin", "gerencia", "administracion"]
          || obraId in userDoc().assignedWorkIds
        );
    }

    function canUploadWorkImage(obraId) {
      return active()
        && (
          userDoc().role in ["admin", "gerencia", "administracion"]
          || (
            userDoc().role in ["supervisor", "fiscalizador", "encargado", "instalador"]
            && obraId in userDoc().assignedWorkIds
          )
        );
    }

    function isAllowedImage() {
      return request.resource != null
        && request.resource.contentType in ["image/jpeg", "image/png", "image/webp"];
    }

    function isAllowedImageSize() {
      return request.resource != null
        && request.resource.size <= 8 * 1024 * 1024;
    }

    match /obras/{obraId}/render/{fileName} {
      allow read: if canUseWork(obraId);
      allow create, update: if canUploadWorkImage(obraId)
        && isAllowedImage()
        && isAllowedImageSize();
      allow delete: if canUploadWorkImage(obraId);
    }

    match /obras/{obraId}/{allPaths=**} {
      allow read: if canUseWork(obraId);
      allow create, update: if canUploadWorkImage(obraId)
        && isAllowedImage()
        && isAllowedImageSize();
      allow delete: if canUploadWorkImage(obraId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
